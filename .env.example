# AI Chat - Choose one provider:
#
# Option 1: OpenRouter (recommended - access to GPT-4o, Claude, etc.)
OPENROUTER_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o
#
# Option 2: OpenAI direct
# OPENAI_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# ElevenLabs API Key (optional - for natural voice narration)
NEXT_PUBLIC_ELEVENLABS_API_KEY=

# Backend API URL (NestJS)
NEXT_PUBLIC_API_URL=https://api-production-bb96.up.railway.app/api/v1
BACKEND_URL=https://api-production-bb96.up.railway.app/api/v1

# Supabase (optional)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
